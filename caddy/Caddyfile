asanokanji.com, www.asanokanji.com {
    root * /var/www/kanji
    file_server
    encode gzip

    # Stripe webhook proxy
    reverse_proxy /stripe-webhook localhost:3001

    # JS/CSS sources : toujours revalider (pas de cache stale)
    @sources {
        path /src/*.js /src/*.css /sw.js
    }
    header @sources Cache-Control "no-cache, must-revalidate"

    # Security headers
    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }
}

